# Copy to `.env` at the repo root (or per app as you split env) and fill values.

# API (apps/api)
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Web (apps/web) — Vite: only vars prefixed with VITE_ are exposed to the client
VITE_API_URL=http://localhost:3000

# Web/API origins (CORS, cookies — refine when auth is wired)
WEB_ORIGIN=http://localhost:5173

# Database (Windows default from `npm run db:dev:setup`, hardened local auth)
DATABASE_URL=postgres://postgres:change-me@localhost:55432/memories
TEST_DATABASE_URL=postgres://postgres:change-me@localhost:55432/memories_test

# Object storage and transcription providers (add when you wire uploads and jobs)
# S3_*
# TRANSCRIPTION_*

# Auth/session (placeholders; align with your platform and Dashboard)
# COOKIE_SECURE=false
# TRUST_PROXY=false
