# Copy this file to sync-agent-chats.local.env in the same directory (gitignored).
# Set the absolute path to your Cursor agent-transcripts folder (the directory that contains *.jsonl).
#
# Examples:
#   Windows: CURSOR_AGENT_TRANSCRIPTS_DIR=C:\Users\you\.cursor\projects\<project-slug>\agent-transcripts
#   Git Bash: CURSOR_AGENT_TRANSCRIPTS_DIR=/c/Users/you/.cursor/projects/<project-slug>/agent-transcripts
#
CURSOR_AGENT_TRANSCRIPTS_DIR=
