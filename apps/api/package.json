{
  "name": "@memories/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env LOG_LEVEL=warn tsx watch src/index.ts",
    "dev:local-auth": "tsx scripts/local-auth-dev.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@memories/shared": "file:../../packages/shared",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "jose": "^6.2.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.0.0",
    "typescript": "~5.9.0",
    "vitest": "^3.0.0"
  }
}
