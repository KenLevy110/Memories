#!/bin/sh

# Sync Cursor agent chat transcripts into the repo before each commit.
powershell.exe -NoProfile -ExecutionPolicy Bypass -File "scripts/sync-agent-chats.ps1"
status=$?
if [ $status -ne 0 ]; then
  echo "pre-commit: transcript sync failed"
  exit $status
fi

# Stage transcript updates automatically.
git add docs/agent-chats
