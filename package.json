{
  "name": "memories",
  "private": true,
  "description": "Legacy product monorepo (@memories/* workspaces): multimodal capture (photos, voice) with server-side transcription",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:all": "concurrently --kill-others-on-fail -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:clean": "npm run dev:clean:api && npm run dev:clean:web",
    "dev:clean:api": "node scripts/kill-dev-port.mjs 3000",
    "dev:clean:web": "node scripts/kill-dev-port.mjs 5173",
    "dev:web": "npm run dev --workspace=@memories/web",
    "dev:api": "npm run dev --workspace=@memories/api",
    "dev:local-auth": "npm run dev:local-auth --workspace=@memories/api",
    "db:dev:setup": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-dev-db.ps1",
    "db:migrate": "npm run db:migrate -w @memories/api",
    "db:prepare": "npm run db:dev:setup && npm run db:migrate",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace=@memories/api --if-present"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "firebase": "^12.13.0"
  }
}
